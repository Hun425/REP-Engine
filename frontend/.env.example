# API URLs (로컬 개발 시에는 Vite proxy가 처리하므로 설정 불필요)
# 직접 지정 시 Vite proxy를 우회하고 해당 URL로 직접 요청합니다.
# VITE_RECOMMENDATION_API_URL=http://localhost:8080/api/v1/recommendations
# VITE_SIMULATOR_API_URL=http://localhost:8084/api/v1/simulator
VITE_GRAFANA_URL=http://localhost:3000

# Feature Flags (optional)
VITE_ENABLE_MONITORING=true
VITE_ENABLE_SIMULATOR=true
